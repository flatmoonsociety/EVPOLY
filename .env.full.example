# EVPOLY full environment template (.env.full.example)
# Generated from .env after dead-key cleanup. Fill secrets before live trading.

# EVPoly environment (.env)
# Load priority in code: process/shell env > .env.
# Each variable below has one-line behavior notes; blank means "no override from this file".

POLY_MM_PROXIES=

# ==================== Core API + Chain Endpoints ====================

# ------------------------------------------------------------
# POLY_GAMMA_API_URL: Polymarket Gamma API base for market discovery. Blank => config/default URL is used.
POLY_GAMMA_API_URL=https://gamma-api.polymarket.com

# ------------------------------------------------------------
# POLY_CLOB_API_URL: Polymarket CLOB API base for auth/order endpoints. Blank => config/default URL is used.
POLY_CLOB_API_URL=https://clob.polymarket.com

# ------------------------------------------------------------
# POLY_POLYGON_RPC_HTTP_URL: Primary Polygon HTTP RPC used for on-chain checks. Blank => runtime may rely on internal defaults/other providers.
POLY_POLYGON_RPC_HTTP_URL=https://1rpc.io/matic

# ------------------------------------------------------------
# POLY_POLYGON_RPC_HTTP_FALLBACK_URL: Backup Polygon HTTP RPC if primary fails. Blank => no explicit fallback from env.
POLY_POLYGON_RPC_HTTP_FALLBACK_URL=https://polygon-rpc.com

# ==================== Credentials ====================

# ------------------------------------------------------------
# POLY_PRIVATE_KEY: EOA private key for local signing. Blank => uses config.json if present; if absent, signed order paths fail.
POLY_PRIVATE_KEY=

# ------------------------------------------------------------
# POLY_PROXY_WALLET_ADDRESS: Proxy wallet address for proxy trading mode. Blank => no proxy override from env.
POLY_PROXY_WALLET_ADDRESS=

# ------------------------------------------------------------
# POLY_SIGNATURE_TYPE: Wallet signature type
POLY_SIGNATURE_TYPE=1
# 1 = Proxy wallet (email signup): no gas fee paid by user (relayer/gasless)
# 2 = Safe wallet (web3 wallet signup like MetaMask/Rabby): no gas fee paid by user (relayer/gasless)
# 0 = EOA wallet: user pays gas fee directly

# ==================== Market Selection ====================
# POLY_ENABLE_ETH_TRADING: Enable ETH markets. Blank => config default is true.
POLY_ENABLE_ETH_TRADING=true

# ------------------------------------------------------------
# POLY_ENABLE_SOLANA_TRADING: Enable Solana markets. Blank => config default is true.
POLY_ENABLE_SOLANA_TRADING=true

# ------------------------------------------------------------
# POLY_ENABLE_XRP_TRADING: Enable XRP markets. Blank => config default is true.
POLY_ENABLE_XRP_TRADING=true

# ==================== Core Trading ====================

# ------------------------------------------------------------
# POLY_CHECK_INTERVAL_MS: Main monitor polling interval. Blank => config default 1000ms.
POLY_CHECK_INTERVAL_MS=1000

# ------------------------------------------------------------
# POLY_FIXED_TRADE_AMOUNT: Base per-entry notional in USD. Blank => config default 1.0.
POLY_FIXED_TRADE_AMOUNT=1.0

# ------------------------------------------------------------
# POLY_HOLD_TO_RESOLUTION: Global hold-to-resolution switch. Blank => config default true.
POLY_HOLD_TO_RESOLUTION=true

# ------------------------------------------------------------
# POLY_MAX_BUY_PRICE: Hard max token price for entries. Blank => config default 0.95.
POLY_MAX_BUY_PRICE=0.95

# ------------------------------------------------------------
# POLY_MIN_TIME_REMAINING_SECONDS: Reject entries too close to market close. Blank => config default 30s.
POLY_MIN_TIME_REMAINING_SECONDS=30

# ==================== Feature Engine V2 ====================

# ------------------------------------------------------------
# EVPOLY_FEATURES_V2_ENABLE: Audit/metadata flag for v2 feature packs in telemetry. Blank => default false.
EVPOLY_FEATURES_V2_ENABLE=true

# ------------------------------------------------------------
# EVPOLY_FEATURES_V2_VERSION: Feature-pack version label persisted in context metadata. Blank => default v2-draft.
EVPOLY_FEATURES_V2_VERSION=v2.1

# ------------------------------------------------------------
# EVPOLY_HL_L4_WEIGHT_5M: HL L4 component weight for 5m composite. Blank => default 0.65.
EVPOLY_HL_L4_WEIGHT_5M=0.65

# ------------------------------------------------------------
# EVPOLY_HL_L4_WEIGHT_15M: HL L4 component weight for 15m composite. Blank => default 0.50.
EVPOLY_HL_L4_WEIGHT_15M=0.50

# ------------------------------------------------------------
# EVPOLY_HL_L4_WEIGHT_1H: HL L4 component weight for 1h composite. Blank => default 0.35.
EVPOLY_HL_L4_WEIGHT_1H=0.35

# ==================== Signals + Feeds ====================

# ------------------------------------------------------------
# EVPOLY_HL_SIGNALS_DIR: HL JSON signal snapshot directory. Blank => default /root/clawd/skills/hl-trader/signals.
EVPOLY_HL_SIGNALS_DIR=/root/clawd/skills/hl-trader/signals

# ------------------------------------------------------------
# EVPOLY_HL_L4_HOURLY_DIR: HL L4 hourly fills directory. Blank => default /root/hl/data/node_fills_by_block/hourly.
EVPOLY_HL_L4_HOURLY_DIR=/root/hl/data/node_fills_by_block/hourly

# ------------------------------------------------------------
# EVPOLY_HL_L4_MAX_LINES_PER_TICK: HL L4 parser line budget per tick. Blank => default 20000.
EVPOLY_HL_L4_MAX_LINES_PER_TICK=20000

# ------------------------------------------------------------
# EVPOLY_HL_L4_MAX_BYTES_PER_TICK: HL L4 parser byte budget per tick. Blank => default 8388608.
EVPOLY_HL_L4_MAX_BYTES_PER_TICK=8388608

# ------------------------------------------------------------
# EVPOLY_BINANCE_WHALE_TRADE_USD: Whale threshold for Binance prints. Blank => default 250000.
EVPOLY_BINANCE_WHALE_TRADE_USD=250000

# ------------------------------------------------------------
# EVPOLY_BINANCE_HIGH_WHALE_TRADE_USD: High-severity whale threshold. Blank => default 750000.
EVPOLY_BINANCE_HIGH_WHALE_TRADE_USD=750000

# ------------------------------------------------------------
# EVPOLY_BINANCE_WHALE_WINDOW_SEC: Whale aggregation window. Blank => default 300s.
EVPOLY_BINANCE_WHALE_WINDOW_SEC=300

# ------------------------------------------------------------
# EVPOLY_BINANCE_WHALE_EVENT_QUEUE_CAP: Max whale events kept in memory. Blank => default 2000.
EVPOLY_BINANCE_WHALE_EVENT_QUEUE_CAP=2000

# ------------------------------------------------------------
# EVPOLY_BINANCE_INACTIVITY_TIMEOUT_SEC: Reconnect if Binance stream stalls this long. Blank => default 30s.
EVPOLY_BINANCE_INACTIVITY_TIMEOUT_SEC=30

# ------------------------------------------------------------
# EVPOLY_BINANCE_MICROFLOW_FLUSH_MS: Microflow flush cadence for Binance events. Blank => default 1000ms.
EVPOLY_BINANCE_MICROFLOW_FLUSH_MS=1000

# ==================== Strategy Toggles + Sizing ====================

# ------------------------------------------------------------
# EVPOLY_SIM_INSTANT_FILL: Simulation-only instant fill shortcut. Blank => default false.
EVPOLY_SIM_INSTANT_FILL=false

# ------------------------------------------------------------
# EVPOLY_RELAXED_ENTRY_FILTERS: Stress-mode relaxed entry validation. Blank => default false.
EVPOLY_RELAXED_ENTRY_FILTERS=false

# ------------------------------------------------------------
# EVPOLY_SIZE_CAP_5M_USD: Optional 5m per-decision size cap. Blank => no additional cap.
EVPOLY_SIZE_CAP_5M_USD=60

# ------------------------------------------------------------
# EVPOLY_SIZE_CAP_15M_USD: Optional 15m per-decision size cap. Blank => no additional cap.
EVPOLY_SIZE_CAP_15M_USD=120

# ------------------------------------------------------------
# EVPOLY_SIZE_CAP_1H_USD: Optional 1h per-decision size cap. Blank => no additional cap.
EVPOLY_SIZE_CAP_1H_USD=240

# ------------------------------------------------------------
# EVPOLY_MAX_ENTRIES_PER_TIMEFRAME_PERIOD: Hard cap for entry submits per TF/period. Blank => default 2.
EVPOLY_MAX_ENTRIES_PER_TIMEFRAME_PERIOD=2
# EVPOLY_MAX_EVCURVE_ENTRIES_PER_TIMEFRAME_PERIOD: EVcurve-specific hard cap for active+inflight entries per TF/period.
EVPOLY_MAX_EVCURVE_ENTRIES_PER_TIMEFRAME_PERIOD=20
# EVPOLY_MAX_EVCURVE_SUBMITS_PER_TOKEN_PERIOD: EVcurve-specific hard cap for submits per (timeframe,period,token,side).
EVPOLY_MAX_EVCURVE_SUBMITS_PER_TOKEN_PERIOD=40

# ------------------------------------------------------------
# EVPOLY_ENTRY_WINDOW_PCT: Fraction of a period where entries are allowed. Blank => default 0.30.
EVPOLY_ENTRY_WINDOW_PCT=0.10
# EVPOLY_ENTRY_ALLOW_CROSS_SPREAD: Allow marketable LIMIT crossing when EV/max-price gates pass. Blank => default true.
EVPOLY_ENTRY_ALLOW_CROSS_SPREAD=true
# EVPOLY_ENTRY_AGGRESSIVE_FILL_TARGET: Base normalized spread target (0..1) for aggressive entry pricing. Blank => default 0.85.
EVPOLY_ENTRY_AGGRESSIVE_FILL_TARGET=0.85
# EVPOLY_ENTRY_ENABLE_EV_GATE: Enable deterministic EV gate for entries. Blank => default true.
EVPOLY_ENTRY_ENABLE_EV_GATE=true
# EVPOLY_ENTRY_EV_FLOOR_BPS: Default EV floor (bps) for entries. Blank => default 10.
EVPOLY_ENTRY_EV_FLOOR_BPS=10
# EVPOLY_ENTRY_FEE_BUFFER_BPS: Fee buffer in entry EV calc. Blank => default 8.
EVPOLY_ENTRY_FEE_BUFFER_BPS=8
# EVPOLY_ENTRY_MODEL_BUFFER_BPS: Model-error buffer in entry EV calc. Blank => default 6.
EVPOLY_ENTRY_MODEL_BUFFER_BPS=6
# EVPOLY_ENTRY_DEFAULT_UNCERTAINTY_BPS: Fallback uncertainty (bps) if LLM omits it. Blank => default 12.
EVPOLY_ENTRY_DEFAULT_UNCERTAINTY_BPS=12
# EVPOLY_ENTRY_HIGH_EDGE_BPS: Threshold to allow more aggressive late-stage entry quoting. Blank => default 25.
EVPOLY_ENTRY_HIGH_EDGE_BPS=25
# EVPOLY_ENTRY_CONFIDENCE_HARD_FLOOR: Minimum confidence floor after signal weighting. Blank => default 0.20.
EVPOLY_ENTRY_CONFIDENCE_HARD_FLOOR=0.20

# ------------------------------------------------------------
# EVPOLY_MAX_LADDER_ENTRIES_PER_PERIOD: Hard cap for ladder rungs per period. Blank => inherits EVPOLY_MAX_ENTRIES_PER_TIMEFRAME_PERIOD.
EVPOLY_MAX_LADDER_ENTRIES_PER_PERIOD=24

# ------------------------------------------------------------
# EVPOLY_MAX_LADDER_SUBMITS_PER_TOKEN_PERIOD: Hard cap for ladder submits per (strategy,timeframe,period,token,side). Blank => inherits EVPOLY_MAX_SUBMITS_PER_TOKEN_PERIOD (default 5).
EVPOLY_MAX_LADDER_SUBMITS_PER_TOKEN_PERIOD=24

# ------------------------------------------------------------
# ==================== Premarket Discovery ====================

# ------------------------------------------------------------
# EVPOLY_PREMARKET_DISCOVERY_BACKOFF_SEC: Backoff between discovery retries. Blank => default 10s.
EVPOLY_PREMARKET_DISCOVERY_BACKOFF_SEC=10

# ------------------------------------------------------------
# EVPOLY_REMOTE_MARKET_DISCOVERY_URL: Optional remote discovery endpoint for timeframe market lookup (premarket/endgame/shared timeframe paths).
# Runtime auto-retries once on `alpha2.evplus.ai` when this URL host is
# `alpha.evplus.ai` and primary request fails with timeout/429/5xx transport errors.
EVPOLY_REMOTE_MARKET_DISCOVERY_URL=https://alpha.evplus.ai/v1/discovery/timeframe

# ------------------------------------------------------------
# EVPOLY_REMOTE_MARKET_DISCOVERY_TOKEN: Optional bearer token for remote timeframe market discovery.
EVPOLY_REMOTE_MARKET_DISCOVERY_TOKEN=

# ------------------------------------------------------------
# EVPOLY_REMOTE_PREMARKET_ALPHA_URL: Optional remote premarket gate endpoint. Expects shared bearer token + proxy wallet.
EVPOLY_REMOTE_PREMARKET_ALPHA_URL=https://alpha.evplus.ai/v1/alpha/premarket/should-trade

# ------------------------------------------------------------
# EVPOLY_REMOTE_PREMARKET_ALPHA_TOKEN: Shared bearer token for remote premarket alpha.
EVPOLY_REMOTE_PREMARKET_ALPHA_TOKEN=

# ------------------------------------------------------------
# EVPOLY_REMOTE_ENDGAME_ALPHA_URL: Remote endgame policy endpoint (tick offsets + submit stale guard).
EVPOLY_REMOTE_ENDGAME_ALPHA_URL=https://alpha.evplus.ai/v1/alpha/endgame/policy

# ------------------------------------------------------------
# EVPOLY_REMOTE_ENDGAME_ALPHA_TOKEN: Shared bearer token for remote endgame alpha.
EVPOLY_REMOTE_ENDGAME_ALPHA_TOKEN=

# ------------------------------------------------------------
# EVPOLY_ENDGAME_ALPHA_REQUIRED: If true, endgame fails closed when alpha policy is missing. Blank => default true.
EVPOLY_ENDGAME_ALPHA_REQUIRED=true

# ------------------------------------------------------------
# EVPOLY_REMOTE_MM_REWARDS_SELECTION_ALPHA_URL: Remote MM rewards selection endpoint (auto mode assignment + forced include resolution).
EVPOLY_REMOTE_MM_REWARDS_SELECTION_ALPHA_URL=https://alpha.evplus.ai/v1/alpha/mm-rewards/selection

# ------------------------------------------------------------
# EVPOLY_REMOTE_MM_REWARDS_ALPHA_TOKEN: Shared bearer token for remote MM rewards selection alpha endpoint.
EVPOLY_REMOTE_MM_REWARDS_ALPHA_TOKEN=

# ------------------------------------------------------------
# EVPOLY_REMOTE_MM_REWARDS_ALPHA_TIMEOUT_MS: Remote MM rewards alpha timeout in milliseconds. Blank => default 1000ms.
EVPOLY_REMOTE_MM_REWARDS_ALPHA_TIMEOUT_MS=1000


# ------------------------------------------------------------
# ==================== Strategy 5 (endgame_sweep_v1) ====================

# ------------------------------------------------------------
# EVPOLY_COINBASE_CHANNEL: Coinbase Exchange WS channel for endgame book feed. Use level2_batch (public) or level2 (requires auth).
EVPOLY_COINBASE_CHANNEL=level2_batch

# ------------------------------------------------------------
# EVPOLY_STRATEGY_ENDGAME_ENABLE: Enable endgame_sweep_v1 strategy loop. Blank => default true.
EVPOLY_STRATEGY_ENDGAME_ENABLE=true

# ------------------------------------------------------------
# EVPOLY_ENDGAME_POLL_MS: Legacy endgame poll interval (kept for fallback). Blank => default 500ms.
EVPOLY_ENDGAME_POLL_MS=50
# EVPOLY_ENDGAME_SAFETY_POLL_MS: Safety wake interval when no tick deadline is near (sleep_until scheduler). Blank => default 500ms.
EVPOLY_ENDGAME_SAFETY_POLL_MS=500
# EVPOLY_ENDGAME_TICK_RANDOM_JITTER_MS: Legacy local jitter (+/- ms). Alpha-owned tick policy path ignores this. Blank => default 50ms.
EVPOLY_ENDGAME_TICK_RANDOM_JITTER_MS=50

# ------------------------------------------------------------
# EVPOLY_ENDGAME_TIMEFRAMES: Comma-separated timeframe scope for endgame (5m,15m,1h,4h). Blank => default 5m,15m,1h,4h.
EVPOLY_ENDGAME_TIMEFRAMES=5m,15m,1h,4h

# ------------------------------------------------------------
# EVPOLY_ENDGAME_SYMBOLS: Comma-separated assets for endgame sweep discovery/routing. Blank => default BTC,ETH,SOL,XRP.
EVPOLY_ENDGAME_SYMBOLS=BTC,ETH,SOL,XRP

# ------------------------------------------------------------
# EVPOLY_ENDGAME_TICK_OFFSETS_SEC: Seconds-to-close checkpoints for endgame submits. Blank => default 65,50,35,20,5.
EVPOLY_ENDGAME_TICK_OFFSETS_SEC=3,1
# EVPOLY_ENDGAME_TICK_OFFSETS_MS: Millisecond checkpoints before close (overrides *_SEC when set).
EVPOLY_ENDGAME_TICK_OFFSETS_MS=3000,1000,100

# ------------------------------------------------------------
# EVPOLY_ENDGAME_BASE_SIZE_USD: Endgame base position size in USD. Blank => default 100.
# Applied by policy with symbol multipliers (BTC 1.0, ETH 0.8, SOL/XRP 0.5) and hard tick split:
# tick0 (t-3000ms)=20%, tick1 (t-1000ms)=40%, tick2 (t-100ms)=40%.
EVPOLY_ENDGAME_BASE_SIZE_USD=

# ------------------------------------------------------------
# EVPOLY_ENDGAME_PER_PERIOD_CAP_USD: Endgame cap per market period. Blank => default 10000.
EVPOLY_ENDGAME_PER_PERIOD_CAP_USD=10000

# ------------------------------------------------------------
# EVPOLY_ENDGAME_MAX_SIGNAL_AGE_MS: Endgame signal freshness gate. Blank => default 60000ms.
EVPOLY_ENDGAME_MAX_SIGNAL_AGE_MS=60000

# ------------------------------------------------------------
# EVPOLY_ENDGAME_ALLOW_CROSS_SPREAD: Allow marketable-limit crossing at/under q_max for endgame entries. Blank => default true.
EVPOLY_ENDGAME_ALLOW_CROSS_SPREAD=true

# ------------------------------------------------------------
# EVPOLY_ENDGAME_SAFETY_STOP_SEC: Endgame no-submit zone before close. Blank => default 2s.
EVPOLY_ENDGAME_SAFETY_STOP_SEC=0

# ------------------------------------------------------------
# EVPOLY_ENDGAME_BOOK_FRESHNESS_MS: Max acceptable PM/Coinbase book age for submit path. Blank => default 1500ms.
EVPOLY_ENDGAME_BOOK_FRESHNESS_MS=1500

# ------------------------------------------------------------
# EVPOLY_ENDGAME_LATENCY_HAIRCUT: Multiplier applied to raw endgame size to absorb latency/slippage. Blank => default 0.85.
EVPOLY_ENDGAME_LATENCY_HAIRCUT=1.0

# ------------------------------------------------------------
# EVPOLY_ENDGAME_EDGE_FLOOR_BPS: Minimum per-share EV floor in bps for endgame entries. Blank => default 12.
EVPOLY_ENDGAME_EDGE_FLOOR_BPS=5

# ------------------------------------------------------------
# EVPOLY_ENDGAME_MIN_ENTRY_PRICE: Endgame entry price floor; buy only when final limit price is strictly above this value. Blank => default 0.5.
EVPOLY_ENDGAME_MIN_ENTRY_PRICE=0.8

# ------------------------------------------------------------
# EVPOLY_ENDGAME_PROB_MIN: Symmetric probability floor for endgame p_up/p_down. Blank => default 0.005.
EVPOLY_ENDGAME_PROB_MIN=0.005

# ------------------------------------------------------------
# EVPOLY_ENDGAME_Z_CAP: Max absolute z used for endgame probability mapping. Blank => default 4.0.
EVPOLY_ENDGAME_Z_CAP=4.0

# ------------------------------------------------------------
# EVPOLY_ENDGAME_MIN_SIGMA_BPS_15S: Minimum 15s sigma floor (bps) for endgame fair-probability scaling. Blank => default 1.0.
EVPOLY_ENDGAME_MIN_SIGMA_BPS_15S=1.0

# ------------------------------------------------------------
# EVPOLY_ENDGAME_SPREAD_TO_SIGMA_MULT: Multiplier from spread-bps to sigma-floor-bps in endgame. Blank => default 10.0.
EVPOLY_ENDGAME_SPREAD_TO_SIGMA_MULT=10.0

# ------------------------------------------------------------
# EVPOLY_ENDGAME_SIGMA_MULT: Conservative multiplier applied to sigma_tau in endgame. Blank => default 1.15.
EVPOLY_ENDGAME_SIGMA_MULT=1.15

# ------------------------------------------------------------
# EVPOLY_ENDGAME_DIVERGENCE_THRESHOLD: Divergence trigger between Polymarket mid and fair probability. Blank => default 0.18.
EVPOLY_ENDGAME_DIVERGENCE_THRESHOLD=0.15

# ------------------------------------------------------------
# EVPOLY_ENDGAME_DIVERGENCE_MIN_SIZE_RATIO: When divergence threshold is hit, size is clamped to this ratio of target notional. Blank => default 0.10.
EVPOLY_ENDGAME_DIVERGENCE_MIN_SIZE_RATIO=0.10


# ------------------------------------------------------------

# ==================== Strategy 7 (evcurve_v1) ====================

# ------------------------------------------------------------
# EVPOLY_STRATEGY_EVCURVE_ENABLE: Enable evcurve_v1 strategy loop. Blank => default true.
EVPOLY_STRATEGY_EVCURVE_ENABLE=true

# ------------------------------------------------------------
# EVPOLY_EVCURVE_MAX_FLIP_PROB: Hard cap for p_flip (above this => skip). Blank => default 0.10.
EVPOLY_EVCURVE_MAX_FLIP_PROB=0.15

# ------------------------------------------------------------
# EVPOLY_EVCURVE_MAXBUY_CURVE: Piecewise max-buy curve points as flip_prob:max_buy_price pairs.
EVPOLY_EVCURVE_MAXBUY_CURVE=0:0.99,0.01:0.98,0.02:0.96,0.03:0.94,0.04:0.92,0.05:0.9,0.06:0.88,0.07:0.85,0.08:0.84,0.09:0.83,0.1:0.82,0.11:0.8,0.12:0.8,0.13:0.75,0.14:0.72,0.15:0.7
# EVPOLY_EVCURVE_15M_T2_MAXBUY_CURVE: Optional 15m T-180s (tick2) max-buy curve override.
EVPOLY_EVCURVE_15M_T2_MAXBUY_CURVE=0:0.99,0.01:0.98,0.02:0.96,0.03:0.94,0.04:0.92,0.05:0.9,0.06:0.88,0.07:0.85,0.08:0.75,0.09:0.72,0.1:0.69,0.11:0.67,0.12:0.65,0.13:0.64,0.14:0.63,0.15:0.62
# EVPOLY_EVCURVE_15M_T2_NO_FAK: For 15m T-180s (tick2), stop after chase (no phase3 FAK fallback).
EVPOLY_EVCURVE_15M_T2_NO_FAK=true
# EVPOLY_EVCURVE_MAXBUY_CURVE_<SYMBOL>: Optional symbol-specific curve override (e.g. SOL/XRP).
EVPOLY_EVCURVE_MAXBUY_CURVE_SOL=0:0.99,0.01:0.98,0.02:0.96,0.03:0.94,0.04:0.9,0.05:0.87,0.06:0.84,0.07:0.79,0.08:0.76,0.09:0.73,0.1:0.7
EVPOLY_EVCURVE_MAXBUY_CURVE_XRP=0:0.99,0.01:0.98,0.02:0.96,0.03:0.94,0.04:0.9,0.05:0.87,0.06:0.84,0.07:0.79,0.08:0.76,0.09:0.73,0.1:0.7

# ------------------------------------------------------------
# EVPOLY_EVCURVE_PM_QUOTE_FRESH_MS: Max age for PM quote pair used in EVcurve quote freshness checks. Blank => default 1500ms.
EVPOLY_EVCURVE_PM_QUOTE_FRESH_MS=1500

# ------------------------------------------------------------
# EVPOLY_EVCURVE_PM_QUOTE_PAIR_SKEW_MS: Max timestamp skew between PM up/down quotes for EVcurve quote freshness checks. Blank => default 800ms.
EVPOLY_EVCURVE_PM_QUOTE_PAIR_SKEW_MS=800

# ------------------------------------------------------------
# EVPOLY_EVCURVE_MIN_BUY_PRICE: EVcurve minimum ask price gate before buy (ask < floor => skip). Blank => default 0.60.
EVPOLY_EVCURVE_MIN_BUY_PRICE=0.60

# ------------------------------------------------------------
# EVPOLY_EVCURVE_BASE_ANCHOR_GRACE_SEC: Max seconds after period open allowed to initialize base proxy if missing (late restart protection). Blank => default 2.
EVPOLY_EVCURVE_BASE_ANCHOR_GRACE_SEC=2
# EVPOLY_PROXY_BASE_EXACT_MAX_DELAY_MS: Max allowed delay from period open for WS/DB base anchor acceptance; 0 => require exact-open and fallback to REST.
EVPOLY_PROXY_BASE_EXACT_MAX_DELAY_MS=0
# EVPOLY_EVCURVE_MAX_LATE_MS: Max allowed lateness after checkpoint deadline for EVcurve trigger.
EVPOLY_EVCURVE_MAX_LATE_MS=60000
# EVPOLY_EVCURVE_CHASE_STOP_ON_FIRST_FILL: Stop EVcurve chase cycle after first detected fill and cancel remainder.
EVPOLY_EVCURVE_CHASE_STOP_ON_FIRST_FILL=false
# EVPOLY_EVCURVE_CHASE_CANCEL_SETTLE_MS: Wait window after cancel before allowing a new place.
EVPOLY_EVCURVE_CHASE_CANCEL_SETTLE_MS=350
# EVPOLY_EVCURVE_CHASE_ACTION_TIMEOUT_MS: Max wait for place action to appear as open-pending before retry logic resumes.
EVPOLY_EVCURVE_CHASE_ACTION_TIMEOUT_MS=1500
# EVPOLY_EVCURVE_BASE_ANCHOR_REST_RETRY_MS: Retry delay when EVcurve REST exact-open anchor is unavailable.
EVPOLY_EVCURVE_BASE_ANCHOR_REST_RETRY_MS=2000

# EVPOLY_EVCURVE_TIMEFRAMES: EVcurve timeframes (15m,1h,4h,1d). 5m is unsupported. Blank => default 15m,1h,4h,1d.
EVPOLY_EVCURVE_TIMEFRAMES=15m,1h,4h,1d

# EVPOLY_EVCURVE_SYMBOLS: EVcurve symbols universe. Blank => default BTC,ETH,SOL,XRP.
EVPOLY_EVCURVE_SYMBOLS=BTC,ETH,SOL,XRP

# EVPOLY_EVCURVE_STRATEGY_CAP_USD: EVcurve non-D1 strategy cap.
EVPOLY_EVCURVE_STRATEGY_CAP_USD=

# EVPOLY_EVCURVE_BASE_SIZE_USD: EVcurve base position size in USD. Blank => default 100.
# Applied by policy with symbol multipliers (BTC 1.0, ETH 0.8, SOL/XRP 0.5) and timeframe multipliers:
# 15m=0.75, 1h=1.0, 4h/1d=1.25.
EVPOLY_EVCURVE_BASE_SIZE_USD=

# EVPOLY_EVCURVE_D1_ENABLE: Force-include EVcurve daily strategy (Noon-to-noon ET), even if EVPOLY_EVCURVE_TIMEFRAMES excludes 1d.
EVPOLY_EVCURVE_D1_ENABLE=true

# EVPOLY_EVCURVE_D1_STRATEGY_CAP_USD: EVcurve D1 strategy cap.
EVPOLY_EVCURVE_D1_STRATEGY_CAP_USD=10000

# EVPOLY_EVCURVE_D1_ZERO_MIN_N: Min sample size gate for flips==0 rule.
EVPOLY_EVCURVE_D1_ZERO_MIN_N=

# EVPOLY_EVCURVE_D1_EV_MIN_N: Min sample size gate for EV gap rule.
EVPOLY_EVCURVE_D1_EV_MIN_N=

# EVPOLY_EVCURVE_D1_EV_GAP: Absolute gap threshold between model p_flip and market implied p_flip.
EVPOLY_EVCURVE_D1_EV_GAP=0.08

# EVPOLY_EVCURVE_SCOPE_CAP_<SYMBOL>_1D: Max D1 notional per symbol/day.

# EVPOLY_STRATEGY_SESSIONBAND_ENABLE: Enable sessionband_v1 strategy loop. Blank => default true.
EVPOLY_STRATEGY_SESSIONBAND_ENABLE=true

# EVPOLY_SESSIONBAND_POLL_MS: SessionBand loop polling interval (ms). Blank => default 250.
EVPOLY_SESSIONBAND_POLL_MS=250

# EVPOLY_SESSIONBAND_SYMBOLS: Comma-separated symbols for SessionBand. Blank => default BTC,ETH,SOL,XRP.
EVPOLY_SESSIONBAND_SYMBOLS=BTC,ETH,SOL,XRP

# EVPOLY_SESSIONBAND_TIMEFRAMES: Comma-separated timeframes for SessionBand (5m,15m,1h,4h).
EVPOLY_SESSIONBAND_TIMEFRAMES=5m,15m,1h,4h

# EVPOLY_SESSIONBAND_BASE_SIZE_USD: SessionBand base position size in USD. Blank => default 100.
# Applied by policy with symbol multipliers (BTC 1.0, ETH 0.8, SOL/XRP 0.5) and tau split:
# tau-2=30%, tau-1=70%.
EVPOLY_SESSIONBAND_BASE_SIZE_USD=

# EVPOLY_SESSIONBAND_FLIP_THRESHOLD_PCT: plan4b rate threshold used to derive watch-start by session.
EVPOLY_SESSIONBAND_FLIP_THRESHOLD_PCT=

# EVPOLY_SESSIONBAND_PREWATCH_SEC: Start this many seconds before tau-trigger (watch_start=tau_trigger-prewatch).
EVPOLY_SESSIONBAND_PREWATCH_SEC=
# EVPOLY_SESSIONBAND_ALLOWED_TAU_SEC: Optional allowlist of tau-sec values for SessionBand entries (comma-separated). Blank => no tau filter.
EVPOLY_SESSIONBAND_ALLOWED_TAU_SEC=1,2

# EVPOLY_SESSIONBAND_BANDS: lead_pct bucket -> acceptable PM best-ask band.
EVPOLY_SESSIONBAND_BANDS=0.0-0.1:0.99-0.99,0.1-0.5:0.98-0.99,0.5-1.0:0.96-0.98,1.0-1.5:0.94-0.96,1.5-2.0:0.90-0.94

# EVPOLY_SESSIONBAND_PROXY_STALE_MS: Max age of proxy feed sample.
EVPOLY_SESSIONBAND_PROXY_STALE_MS=

# EVPOLY_SESSIONBAND_BOOK_FRESHNESS_MS: Max tolerated orderbook quote fetch age.
EVPOLY_SESSIONBAND_BOOK_FRESHNESS_MS=

# EVPOLY_SESSIONBAND_SINGLE_ATTEMPT_PER_PERIOD: If true, at most one submit attempt per symbol/tf/period.
EVPOLY_SESSIONBAND_SINGLE_ATTEMPT_PER_PERIOD=

# EVPOLY_SESSIONBAND_BASE_ANCHOR_GRACE_SEC: Allowed delay after open to initialize base if no DB restore.
EVPOLY_SESSIONBAND_BASE_ANCHOR_GRACE_SEC=

# EVPOLY_SESSIONBAND_STRATEGY_CAP_USD: Strategy-wide notional cap budget for SessionBand loop.
EVPOLY_SESSIONBAND_STRATEGY_CAP_USD=10000

# EVPOLY_STRATEGY_EVSNIPE_ENABLE: Enable EVSnipe hard-hit strategy loop. Blank => default true.
EVPOLY_STRATEGY_EVSNIPE_ENABLE=true

# EVPOLY_EVSNIPE_SYMBOLS: Binance/Polymarket symbols to watch for hit-price markets.
EVPOLY_EVSNIPE_SYMBOLS=BTC,ETH,SOL,XRP

# EVPOLY_EVSNIPE_DISCOVERY_REFRESH_SEC: Active hit-market discovery refresh cadence.
EVPOLY_EVSNIPE_DISCOVERY_REFRESH_SEC=

# EVPOLY_EVSNIPE_DISCOVERY_LIMIT: Gamma active market scan limit for EVSnipe.
EVPOLY_EVSNIPE_DISCOVERY_LIMIT=

# EVPOLY_REMOTE_EVSNIPE_DISCOVERY_URL: Remote endpoint for EVSnipe market-spec discovery (remote-first; local fallback if remote is unavailable).
EVPOLY_REMOTE_EVSNIPE_DISCOVERY_URL=https://alpha.evplus.ai/v1/discovery/evsnipe

# EVPOLY_REMOTE_EVSNIPE_DISCOVERY_TOKEN: Bearer token for remote EVSnipe market-spec discovery.
EVPOLY_REMOTE_EVSNIPE_DISCOVERY_TOKEN=

# EVPOLY_EVSNIPE_MAX_DAYS_TO_EXPIRY: Only trade hit markets expiring within this many days.
EVPOLY_EVSNIPE_MAX_DAYS_TO_EXPIRY=

# EVPOLY_EVSNIPE_SIZE_USD: Total EVSnipe size per hit signal (split pre-leg + confirm-leg).
EVPOLY_EVSNIPE_SIZE_USD=

# EVPOLY_EVSNIPE_PRE_TRIGGER_BPS: Pre-hit trigger band (in bps from strike) for first leg.
EVPOLY_EVSNIPE_PRE_TRIGGER_BPS=

# EVPOLY_EVSNIPE_PRE_LEG_RATIO: Fraction of EVSnipe size sent on pre-hit trigger.
EVPOLY_EVSNIPE_PRE_LEG_RATIO=

# EVPOLY_EVSNIPE_CROSS_ASK_LEVELS: FAK cross depth (use up to best ask N, still bounded by max price).
EVPOLY_EVSNIPE_CROSS_ASK_LEVELS=

# EVPOLY_EVSNIPE_BINANCE_STALE_MS: Drop stale Binance trade ticks older than this threshold.
EVPOLY_EVSNIPE_BINANCE_STALE_MS=

# EVPOLY_EVSNIPE_STRATEGY_CAP_USD: EVSnipe in-loop notional cap.
EVPOLY_EVSNIPE_STRATEGY_CAP_USD=10000

# EVPOLY_EVSNIPE_MAX_INFLIGHT_TASKS: Hard concurrency cap for EVSnipe execution workers.
EVPOLY_EVSNIPE_MAX_INFLIGHT_TASKS=

# ==================== Arbiter (shared risk + conflict control) ====================

# ------------------------------------------------------------
# EVPOLY_ARB_ENABLE: Enable central arbiter enforcement. Blank => default true.
EVPOLY_ARB_ENABLE=true

# ------------------------------------------------------------
# EVPOLY_ARB_MODE: Arbiter scoring mode (priority|weighted). Blank => default priority.
EVPOLY_ARB_MODE=priority

# ------------------------------------------------------------
# EVPOLY_ARB_CONFLICT_POLICY: Opposite-side conflict policy (pick_best|skip_both). Blank => default pick_best.
EVPOLY_ARB_CONFLICT_POLICY=pick_best

# ------------------------------------------------------------
# EVPOLY_ARB_GLOBAL_MAX_USD: Arbiter global USD budget cap. Blank => default 100000.
EVPOLY_ARB_GLOBAL_MAX_USD=100000

# ------------------------------------------------------------
# EVPOLY_ARB_STRAT_PREMARKET_MAX_USD: Per-strategy cap for premarket_v1. Blank => inherits global cap.
EVPOLY_ARB_STRAT_PREMARKET_MAX_USD=50000


# EVPOLY_ARB_STRAT_ENDGAME_MAX_USD: Per-strategy cap for endgame_sweep_v1. Blank => inherits global cap.
EVPOLY_ARB_STRAT_ENDGAME_MAX_USD=12000

# ------------------------------------------------------------

# EVPOLY_ARB_STRAT_EVCURVE_MAX_USD: Per-strategy cap for evcurve_v1. Blank => inherits global cap.
EVPOLY_ARB_STRAT_EVCURVE_MAX_USD=10000

# EVPOLY_ARB_STRAT_SESSIONBAND_MAX_USD: Per-strategy cap for sessionband_v1. Blank => inherits global cap.
EVPOLY_ARB_STRAT_SESSIONBAND_MAX_USD=10000

# EVPOLY_ARB_STRAT_EVSNIPE_MAX_USD: Per-strategy cap for evsnipe_v1. Blank => inherits global cap.
EVPOLY_ARB_STRAT_EVSNIPE_MAX_USD=10000

# EVPOLY_ENTRY_POST_ONLY: Global default for entry BUY orders to enforce exchange post-only. Blank => default false.
EVPOLY_ENTRY_POST_ONLY=true

# ------------------------------------------------------------
# EVPOLY_ENTRY_POST_ONLY_PREMARKET: Override post-only for premarket_v1 entries. Blank => inherits EVPOLY_ENTRY_POST_ONLY.

# ------------------------------------------------------------
# EVPOLY_ENTRY_POST_ONLY_ENDGAME: Override post-only for endgame_sweep_v1 entries. Blank => inherits EVPOLY_ENTRY_POST_ONLY.
EVPOLY_ENTRY_POST_ONLY_ENDGAME=false

# ------------------------------------------------------------

# ------------------------------------------------------------
# EVPOLY_MAX_ENDGAME_ENTRIES_PER_TIMEFRAME_PERIOD: Hard cap for endgame entries per timeframe/period. Blank => default 5.
EVPOLY_MAX_ENDGAME_ENTRIES_PER_TIMEFRAME_PERIOD=5

# ------------------------------------------------------------
# EVPOLY_MAX_ENDGAME_SUBMITS_PER_TOKEN_PERIOD: Submit cap for endgame per token/period. Blank => default 2x entries cap.
EVPOLY_MAX_ENDGAME_SUBMITS_PER_TOKEN_PERIOD=10

# ------------------------------------------------------------
# EVPOLY_MAX_ENDGAME_REVERT_ENTRIES_PER_TIMEFRAME_PERIOD: Hard cap for endgame-revert entries per timeframe/period. Blank => default mirrors endgame cap.
EVPOLY_MAX_ENDGAME_REVERT_ENTRIES_PER_TIMEFRAME_PERIOD=4

# ------------------------------------------------------------
# EVPOLY_MAX_ENDGAME_REVERT_SUBMITS_PER_TOKEN_PERIOD: Submit cap for endgame-revert per token/period. Blank => default 2x entries cap.
EVPOLY_MAX_ENDGAME_REVERT_SUBMITS_PER_TOKEN_PERIOD=8

# EVPOLY_MAX_SESSIONBAND_ENTRIES_PER_TIMEFRAME_PERIOD: Hard cap for sessionband entries per timeframe/period.
EVPOLY_MAX_SESSIONBAND_ENTRIES_PER_TIMEFRAME_PERIOD=1

# EVPOLY_MAX_SESSIONBAND_SUBMITS_PER_TOKEN_PERIOD: Submit cap for sessionband per token/period.
EVPOLY_MAX_SESSIONBAND_SUBMITS_PER_TOKEN_PERIOD=1

# EVPOLY_MAX_EVSNIPE_ENTRIES_PER_TIMEFRAME_PERIOD: Hard cap for EVSnipe entries per timeframe/period.
EVPOLY_MAX_EVSNIPE_ENTRIES_PER_TIMEFRAME_PERIOD=4

# EVPOLY_MAX_EVSNIPE_SUBMITS_PER_TOKEN_PERIOD: Submit cap for EVSnipe per token/period.
EVPOLY_MAX_EVSNIPE_SUBMITS_PER_TOKEN_PERIOD=4

# ------------------------------------------------------------
# EVPOLY_ENTRY_DEDUPE_COOLDOWN_MS: Enqueue dedupe cooldown for identical logical keys. Blank => default 1500ms.
EVPOLY_ENTRY_DEDUPE_COOLDOWN_MS=1500

# EVPOLY_ENTRY_RECENT_DONE_TTL_MM_REWARDS_MS: Worker recent-done cooldown override for mm_rewards_v1 keys.
# Lower than global recent-done TTL so MM ladder rungs can be replenished quickly without 10s dead time.
EVPOLY_ENTRY_RECENT_DONE_TTL_MM_REWARDS_MS=750

# ------------------------------------------------------------
# EVPOLY_ENTRY_RECENT_DONE_TTL_MS: Worker recent-complete suppression TTL. Blank => default 10000ms.
EVPOLY_ENTRY_RECENT_DONE_TTL_MS=10000

# ------------------------------------------------------------
# EVPOLY_ENTRY_FAILURE_COOLDOWN_MS: Generic failure cooldown before retrying same key. Blank => default 8000ms.
EVPOLY_ENTRY_FAILURE_COOLDOWN_MS=8000

# ------------------------------------------------------------
# EVPOLY_ENTRY_RETRYABLE_COOLDOWN_MS: Retryable-failure cooldown window. Blank => default 3000ms.
EVPOLY_ENTRY_RETRYABLE_COOLDOWN_MS=3000

# ------------------------------------------------------------
# EVPOLY_ENTRY_PARAMETER_INVALID_COOLDOWN_MS: Cooldown for min-size/tick invalid orders. Blank => default 30000ms.
EVPOLY_ENTRY_PARAMETER_INVALID_COOLDOWN_MS=30000

# ------------------------------------------------------------
# EVPOLY_ENTRY_MARKET_NOT_READY_COOLDOWN_MS: Cooldown when market isn’t ready. Blank => default 2000ms.
EVPOLY_ENTRY_MARKET_NOT_READY_COOLDOWN_MS=2000

# ------------------------------------------------------------
# EVPOLY_ENTRY_MARKET_NOT_READY_JITTER_MS: Jitter added for market-not-ready retries. Blank => default 500ms.
EVPOLY_ENTRY_MARKET_NOT_READY_JITTER_MS=500

# ------------------------------------------------------------
# EVPOLY_ENTRY_RETRY_WINDOW_MS: Rolling window for retry/failure counters. Blank => default 60000ms.
EVPOLY_ENTRY_RETRY_WINDOW_MS=60000

# ------------------------------------------------------------
# EVPOLY_ENTRY_MAX_FAILURES_PER_WINDOW: Max failures per key per retry window. Blank => default 4.
EVPOLY_ENTRY_MAX_FAILURES_PER_WINDOW=4

# ------------------------------------------------------------
# EVPOLY_ENTRY_ALLOWANCE_BACKOFF_MS: Backoff when allowance/balance errors happen. Blank => default 60000ms.
EVPOLY_ENTRY_ALLOWANCE_BACKOFF_MS=60000

# ------------------------------------------------------------
# EVPOLY_ENTRY_WARNING_COOLDOWN_MS: Warning log cooldown for repeated entry drops. Blank => default 8000ms.
EVPOLY_ENTRY_WARNING_COOLDOWN_MS=8000

# ------------------------------------------------------------
# EVPOLY_ENTRY_EVENT_COOLDOWN_MS: Cooldown for repetitive entry event logs. Blank => default 600000ms.
EVPOLY_ENTRY_EVENT_COOLDOWN_MS=600000

# ==================== Redemption Sweep ====================

# ------------------------------------------------------------
# EVPOLY_REDEMPTION_SWEEP_MINUTE: Minute-of-hour to run scheduled sweep. Blank => default 50.
EVPOLY_REDEMPTION_SWEEP_MINUTE=50

# ------------------------------------------------------------
# EVPOLY_REDEMPTION_SWEEP_INTERVAL_HOURS: Hour interval for scheduled redemption sweeps. 1=hourly, 4=every 4h. Blank => default 1.
EVPOLY_REDEMPTION_SWEEP_INTERVAL_HOURS=1

# ------------------------------------------------------------
# EVPOLY_REDEMPTION_STARTUP_CATCHUP_ENABLE: Track stale startup state only. In scheduled mode, startup will not submit immediately. Blank => default true.
EVPOLY_REDEMPTION_STARTUP_CATCHUP_ENABLE=true

# ------------------------------------------------------------
# EVPOLY_REDEMPTION_STARTUP_SUBMIT_ENABLE: Allow startup catch-up to submit redemptions immediately. Blank => default false.
EVPOLY_REDEMPTION_STARTUP_SUBMIT_ENABLE=false

# ------------------------------------------------------------
# EVPOLY_REDEMPTION_STARTUP_CATCHUP_STALE_MINUTES: Staleness threshold for startup catch-up. Blank => default 65.
EVPOLY_REDEMPTION_STARTUP_CATCHUP_STALE_MINUTES=65

# ------------------------------------------------------------
# EVPOLY_REDEMPTION_MAX_CONDITIONS_PER_SWEEP: Max condition redemptions per scheduled sweep (batch size). Blank => default 3.
EVPOLY_REDEMPTION_MAX_CONDITIONS_PER_SWEEP=10

# ------------------------------------------------------------
# EVPOLY_REDEMPTION_CONDITION_RETRY_SECONDS: Cooldown before retrying the same failed condition. Blank => default 3600s.
EVPOLY_REDEMPTION_CONDITION_RETRY_SECONDS=3600

# ------------------------------------------------------------
# EVPOLY_REDEMPTION_RECENT_ATTEMPTS_LIMIT: In-memory/admin status history size for redemption attempt details.
EVPOLY_REDEMPTION_RECENT_ATTEMPTS_LIMIT=100

# ------------------------------------------------------------
# EVPOLY_WALLET_POSITIONS_RETRY_ATTEMPTS: Retry attempts for Data API /positions scan before treating scan as failed. Blank => default 3.
EVPOLY_WALLET_POSITIONS_RETRY_ATTEMPTS=3

# ------------------------------------------------------------
# EVPOLY_WALLET_POSITIONS_RETRY_BASE_MS: Base backoff (ms) for /positions retries (exponential). Blank => default 200.
EVPOLY_WALLET_POSITIONS_RETRY_BASE_MS=200

# ------------------------------------------------------------
# EVPOLY_MARKET_CONSTRAINTS_RETRY_ATTEMPTS: Retry attempts for market constraints (/markets/{condition_id}) before failing precheck. Blank => default 2.
EVPOLY_MARKET_CONSTRAINTS_RETRY_ATTEMPTS=2

# ------------------------------------------------------------
# EVPOLY_MARKET_CONSTRAINTS_RETRY_BASE_MS: Base backoff (ms) for market-constraints retries (exponential). Blank => default 120.
EVPOLY_MARKET_CONSTRAINTS_RETRY_BASE_MS=120

# ------------------------------------------------------------
# EVPOLY_REDEMPTION_POSITIONS_WARNING_COOLDOWN_SEC: Cooldown for repeating redemption /positions warnings. Blank => default 120.
EVPOLY_REDEMPTION_POSITIONS_WARNING_COOLDOWN_SEC=120

# ==================== Merge Sweep ====================

# ------------------------------------------------------------
# EVPOLY_MERGE_SWEEP_MINUTE: Minute-of-hour to run scheduled merge sweep.
EVPOLY_MERGE_SWEEP_MINUTE=40

# ------------------------------------------------------------
# EVPOLY_MERGE_SWEEP_INTERVAL_HOURS: Hour interval for scheduled merge sweep.
EVPOLY_MERGE_SWEEP_INTERVAL_HOURS=1

# ------------------------------------------------------------
# EVPOLY_MERGE_MIN_PAIRS_SHARES: Minimum min(UP,DOWN) shares to attempt merge on a condition.
EVPOLY_MERGE_MIN_PAIRS_SHARES=1

# ------------------------------------------------------------
# EVPOLY_MERGE_MAX_CONDITIONS_PER_SWEEP: Max merge submits per sweep.
EVPOLY_MERGE_MAX_CONDITIONS_PER_SWEEP=0

# ------------------------------------------------------------
# EVPOLY_MERGE_RECENT_LOG_LIMIT: In-memory/admin status history size for merge submit details.
EVPOLY_MERGE_RECENT_LOG_LIMIT=100

# ==================== Runtime Health + Freshness ====================

# ------------------------------------------------------------
# EVPOLY_MAX_SIGNAL_AGE_MS: Global decider freshness threshold. Blank => default 60000ms.
EVPOLY_MAX_SIGNAL_AGE_MS=60000

# ------------------------------------------------------------
# EVPOLY_SIGNAL_LIVENESS_CHECK_SEC: Signal pipeline health-check interval. Blank => default 20s.
EVPOLY_SIGNAL_LIVENESS_CHECK_SEC=20

# ------------------------------------------------------------
# EVPOLY_SIGNAL_LIVENESS_STALE_MS: Signal stale threshold for liveness checks. Blank => default 180000ms.
EVPOLY_SIGNAL_LIVENESS_STALE_MS=180000

# ------------------------------------------------------------
# EVPOLY_SIGNAL_FAIL_FAST: Exit process if signal pipeline is unhealthy. Blank => default true.
EVPOLY_SIGNAL_FAIL_FAST=true

# ==================== API/Order/DB Operational Limits ====================

# ------------------------------------------------------------
# EVPOLY_LIMIT_ORDER_TTL_SECONDS: Default LIMIT BUY TTL if expiration not set. Blank => default 1200s.
EVPOLY_LIMIT_ORDER_TTL_SECONDS=1200

# ------------------------------------------------------------
# EVPOLY_ORDER_RECONCILE_INTERVAL_MS: Exchange reconcile cadence for pending orders. Blank => default 30000ms.
EVPOLY_ORDER_RECONCILE_INTERVAL_MS=30000
# EVPOLY_ORDER_RECONCILE_RETRY_MAX_ROWS: Max stale/reconcile_failed rows retried per periodic cycle.
EVPOLY_ORDER_RECONCILE_RETRY_MAX_ROWS=24
# EVPOLY_ORDER_RECONCILE_RETRY_MIN_AGE_MS: Minimum age before retrying stale/reconcile_failed rows.
EVPOLY_ORDER_RECONCILE_RETRY_MIN_AGE_MS=300000
# EVPOLY_ORDER_RECONCILE_RETRY_MAX_PERIOD_AGE_SEC: Skip retrying very old periods in periodic reconcile.
EVPOLY_ORDER_RECONCILE_RETRY_MAX_PERIOD_AGE_SEC=172800

# ------------------------------------------------------------
# EVPOLY_PRICE_RETRY_ATTEMPTS: Price-fetch retries for transient errors. Blank => default 3.
EVPOLY_PRICE_RETRY_ATTEMPTS=5

# ------------------------------------------------------------
# EVPOLY_PRICE_RETRY_BASE_MS: Base delay for price-fetch retry backoff. Blank => default 200ms.
EVPOLY_PRICE_RETRY_BASE_MS=300

# ------------------------------------------------------------
# EVPOLY_DB_BUSY_TIMEOUT_MS: SQLite busy timeout. Blank => default 5000ms.
EVPOLY_DB_BUSY_TIMEOUT_MS=5000

# ------------------------------------------------------------
# EVPOLY_STARTUP_BALANCE_CHECK_TIMEOUT_MS: Timeout for per-token startup balance call. Blank => default 5000ms.
EVPOLY_STARTUP_BALANCE_CHECK_TIMEOUT_MS=5000

# ------------------------------------------------------------
# EVPOLY_STARTUP_BALANCE_SCAN_BUDGET_MS: Total startup budget for balance scan/restore. Blank => default 20000ms.
EVPOLY_STARTUP_BALANCE_SCAN_BUDGET_MS=20000

# ------------------------------------------------------------
# EVPOLY_STARTUP_CATCHUP_TIMEOUT_SECONDS: Timeout budget for startup catchup routines. Blank => default 120s.
EVPOLY_STARTUP_CATCHUP_TIMEOUT_SECONDS=120

# ------------------------------------------------------------
# EVPOLY_LADDER_CANCEL_CHECK_MS: Ladder cancel-maintenance loop interval. Blank => default 200ms.
EVPOLY_LADDER_CANCEL_CHECK_MS=200

# ------------------------------------------------------------
# EVPOLY_SIM_PENDING_ORDER_MAX_AGE_SEC: Simulation stale pending-order prune threshold. Blank => default 900s.
EVPOLY_SIM_PENDING_ORDER_MAX_AGE_SEC=1800

# ------------------------------------------------------------
# EVPOLY_SIM_NO_ORDERBOOK_DROP_AGE_SEC: Simulation drop threshold when orderbook missing. Blank => default 120s.
EVPOLY_SIM_NO_ORDERBOOK_DROP_AGE_SEC=300

# ------------------------------------------------------------
# EVPOLY_MARKET_PRICE_FILE_KEEP_PERIODS: Number of period price files retained. Blank => default 8.
EVPOLY_MARKET_PRICE_FILE_KEEP_PERIODS=8

# ------------------------------------------------------------
# EVPOLY_ALLOWANCE_DIAGNOSTICS: Print detailed allowance diagnostics. Blank => default false.
EVPOLY_ALLOWANCE_DIAGNOSTICS=false

# ==================== Logging, History, Admin API ====================

# ------------------------------------------------------------
# EVPOLY_EVENTS_MAX_BYTES: events.jsonl rotation threshold bytes. Blank => default 52428800.
EVPOLY_EVENTS_MAX_BYTES=20971520

# ------------------------------------------------------------
# EVPOLY_EVENTS_ROTATE_KEEP: Number of rotated events files to keep. Blank => default 5.
EVPOLY_EVENTS_ROTATE_KEEP=3

# ------------------------------------------------------------
# EVPOLY_EVENT_WRITE_WARN_COOLDOWN_MS: Cooldown for repeated event-log write warnings. Blank => default 60000ms.
EVPOLY_EVENT_WRITE_WARN_COOLDOWN_MS=60000

EVPOLY_STRATEGY_PREMARKET_ENABLE=true

# ------------------------------------------------------------
# EVPOLY_HISTORY_FLUSH_EVERY: Flush history.toml every N writes. Blank => default 32.
EVPOLY_HISTORY_FLUSH_EVERY=32

# ------------------------------------------------------------
# EVPOLY_HISTORY_MAX_BYTES: history.toml rotation threshold bytes. Blank => default 104857600.
EVPOLY_HISTORY_MAX_BYTES=33554432

# ------------------------------------------------------------
# EVPOLY_HISTORY_ROTATE_KEEP: Number of rotated history files to keep. Blank => default 7.
EVPOLY_HISTORY_ROTATE_KEEP=3

# ------------------------------------------------------------
# Disk retention helpers for scripts/evpoly_retention_cleanup.sh.
EVPOLY_DB_BACKUP_RETENTION_DAYS=3
EVPOLY_HISTORY_DIR_RETENTION_DAYS=3
# Cron schedule used by scripts/install_evpoly_retention_cron.sh.
EVPOLY_RETENTION_CRON_EXPR=17 * * * *

# ------------------------------------------------------------
# ./ev startup disk guard.
EV_DISK_GUARD_ENABLE=1
EV_DISK_GUARD_MIN_FREE_GB=8
EV_DISK_AUTO_PRUNE_ENABLE=1
EV_DISK_AUTO_PRUNE_CROSS_REPOS=1
EV_DISK_AUTO_PRUNE_DEPLOY_TARGET=1

# ------------------------------------------------------------
# EVPOLY_ADMIN_API_ENABLE: Enable local admin API endpoints. Blank => default false.
EVPOLY_ADMIN_API_ENABLE=

# ------------------------------------------------------------
# EVPOLY_ADMIN_API_BIND: Admin API bind address. Blank => default 127.0.0.1:8787.
EVPOLY_ADMIN_API_BIND=127.0.0.1:8787

# ------------------------------------------------------------
# EVPOLY_ADMIN_BIND: Deprecated alias of EVPOLY_ADMIN_API_BIND.

# ------------------------------------------------------------
# EVPOLY_ADMIN_API_TOKEN: Required when EVPOLY_ADMIN_API_ENABLE=true. `scripts/remote_onboard.py` auto-generates this if missing.
EVPOLY_ADMIN_API_TOKEN=

# ------------------------------------------------------------
# EVPOLY_EQUITY_PARALLELISM: Concurrency for equity valuation requests. Blank => default 8.
EVPOLY_EQUITY_PARALLELISM=8

# ==================== Adaptive Loop ====================



EVPOLY_PM_WS_MARKET_STALE_MS=1000
EVPOLY_PM_WS_MARKET_SHARDS=4
EVPOLY_PM_WS_MARKET_LAG_IGNORED_LOG_MIN_INTERVAL_MS=
EVPOLY_PM_WS_MARKET_UNSTABLE_WINDOW_SEC=
EVPOLY_PM_WS_MARKET_RECONNECT_JITTER_MS=300
EVPOLY_PM_HEARTBEAT_ENABLE=
EVPOLY_PM_HEARTBEAT_SEC=15
EVPOLY_MARKET_PREWARM_ENABLE=
EVPOLY_MARKET_PREWARM_POLL_SEC=15
EVPOLY_MARKET_PREWARM_BACKOFF_MS=10000
EVPOLY_MARKET_PREWARM_HORIZON_5M=2
EVPOLY_MARKET_PREWARM_HORIZON_15M=2
EVPOLY_MARKET_PREWARM_HORIZON_1H=1
EVPOLY_MARKET_PREWARM_HORIZON_4H=1
EVPOLY_PREMARKET_BATCH_ENQUEUE_CHUNK=24
# Batch place via POST /orders for premarket/mm eligible submits
EVPOLY_BATCH_PLACE_ENABLE=true
EVPOLY_BATCH_PLACE_MAX_ORDERS=10
EVPOLY_BATCH_PLACE_FLUSH_MS=8
EVPOLY_BATCH_PLACE_QUEUE_CAP=2048
EVPOLY_PREMARKET_SCOPE_LANE_ENABLE=true
EVPOLY_PREMARKET_SCOPE_LANE_IDLE_TTL_SEC=180

# ==================== Runtime Parallelism + Near-Base Skip ====================

# EVPOLY_ENTRY_WORKER_COUNT: Number of parallel arbiter execution workers.
EVPOLY_ENTRY_WORKER_COUNT=4
# Dedicated worker pools
EVPOLY_ENTRY_WORKER_COUNT_CRITICAL=4
EVPOLY_ENTRY_WORKER_COUNT_ENDGAME=4
EVPOLY_ENTRY_WORKER_COUNT_SESSIONBAND=4

# EVPOLY_PREWARM_TOKEN_CACHE_MAX: Max cached token metadata entries before prewarm cache reset.
EVPOLY_PREWARM_TOKEN_CACHE_MAX=10000

# EVPOLY_CONSTRAINT_CACHE_MAX: Max market-constraint cache entries retained in Trader.
EVPOLY_CONSTRAINT_CACHE_MAX=5000
# EVPOLY_CONSTRAINT_CACHE_TTL_MS: Freshness window for trader market-constraint cache.
EVPOLY_CONSTRAINT_CACHE_TTL_MS=180000
# EVPOLY_CONSTRAINT_CACHE_STALE_FALLBACK_MS: Allow stale constraint fallback on transient read failures (429/timeout).
EVPOLY_CONSTRAINT_CACHE_STALE_FALLBACK_MS=900000

# EVPOLY_NEAR_BASE_SKIP_BPS: Skip entries when proxy/base absolute distance is below this threshold (bps).
EVPOLY_NEAR_BASE_SKIP_BPS=

# EVPOLY_NEAR_BASE_SKIP_ENABLE_EVCURVE: Apply near-base skip to evcurve_v1.
EVPOLY_NEAR_BASE_SKIP_ENABLE_EVCURVE=

# EVPOLY_NEAR_BASE_SKIP_ENABLE_SESSIONBAND: Apply near-base skip to sessionband_v1.
EVPOLY_NEAR_BASE_SKIP_ENABLE_SESSIONBAND=
# EVPOLY_PREMARKET_BASE_SIZE_USD: Premarket base side size in USD. Blank => default 100.
# Applied by policy with symbol multipliers (BTC 1.0, ETH 0.8, SOL/XRP 0.5) and timeframe multipliers:
# 5m=0.75, 15m=1.0, 1h/4h=1.25.
EVPOLY_PREMARKET_BASE_SIZE_USD=
# EVPOLY_PREMARKET_TP_ENABLE: Delayed premarket TP worker (15m/1h/4h only), starts at +5m from market open.
# true => enabled (default), false => disabled.
EVPOLY_PREMARKET_TP_ENABLE=true
EVPOLY_PREMARKET_ACTIVE_CAP_PER_ASSET=100
EVPOLY_MAX_LADDER_ENTRIES_PER_PERIOD_BTC=24
EVPOLY_MAX_LADDER_ENTRIES_PER_PERIOD_ETH=24
EVPOLY_MAX_LADDER_ENTRIES_PER_PERIOD_SOL=24
EVPOLY_MAX_LADDER_ENTRIES_PER_PERIOD_XRP=24
EVPOLY_PREMARKET_EXPIRE_5M_SEC=260
EVPOLY_PREMARKET_EXPIRE_5M_HIGH_RUNG_MIN_PRICE=0.30
EVPOLY_PREMARKET_EXPIRE_5M_HIGH_RUNG_SEC=240
EVPOLY_PREMARKET_EXPIRE_5M_BASE_RUNG_SEC=260
EVPOLY_PREMARKET_EXPIRE_15M_SEC=270
EVPOLY_PREMARKET_EXPIRE_1H_SEC=320
EVPOLY_PREMARKET_EXPIRE_4H_SEC=500
EVPOLY_PREMARKET_CANCEL_AFTER_OPEN_5M_SEC=20
EVPOLY_PREMARKET_CANCEL_AFTER_OPEN_15M_SEC=15
EVPOLY_PREMARKET_CANCEL_AFTER_OPEN_1H_SEC=60
EVPOLY_PREMARKET_CANCEL_AFTER_OPEN_4H_SEC=180
EVPOLY_PREMARKET_CANCEL_PREOPEN_TRIM_20_OFFSET_SEC=-15
EVPOLY_PREMARKET_CANCEL_PREOPEN_TRIM_15_OFFSET_SEC=-5

# =============================
# MM Rewards (Canary Live)
# =============================
EVPOLY_STRATEGY_MM_REWARDS_ENABLE=false
# Startup order cleanup:
# - keep global cancel-all ON by default
# - but skip it when mm_rewards is enabled so weak-exit inventory SELLs are not wiped on restart
EVPOLY_STARTUP_CANCEL_ALL_ORDERS=
EVPOLY_MM_HARD_DISABLE=false
EVPOLY_MM_MODE=live
# `auto`: reward-page scanner only (local path).
