# Scale computed reward-min shares target for MM rung sizing/scoring checks (1.0 = unchanged floor).
EVPOLY_MM_REWARD_MIN_TARGET_MULT=
# Local MM market gate: skip market when rewards.min_size exceeds this value (0 = disabled).
# Unit follows EVPOLY_MM_REWARD_MIN_SIZE_UNIT (shares|usd).
EVPOLY_MM_MAX_REWARD_MIN_SIZE=
# Multiple single-market selectors (comma-separated). Supports full URLs.
# Used only in `hybrid` mode.
EVPOLY_MM_SINGLE_MARKET_SLUGS=fed-decision-in-april/will-the-fed-decrease-interest-rates-by-25-bps-after-the-april-2026-meeting,fed-decision-in-april/will-there-be-no-change-in-fed-interest-rates-after-the-april-2026-meeting,fed-decision-in-march-885/will-the-fed-decrease-interest-rates-by-25-bps-after-the-march-2026-meeting,fed-decision-in-march-885/will-there-be-no-change-in-fed-interest-rates-after-the-march-2026-meeting,who-will-trump-nominate-as-fed-chair/will-trump-nominate-kevin-warsh-as-the-next-fed-chair
EVPOLY_MM_SINGLE_MARKET_MAX_ENTRY_FILLS=
EVPOLY_MAX_MM_REWARDS_ENTRIES_PER_TIMEFRAME_PERIOD=200

EVPOLY_EVCURVE_CHASE_LADDER_ENABLE=

EVPOLY_EVCURVE_CHASE_LADDER_RUNGS=10

EVPOLY_EVCURVE_CHASE_LADDER_STEP_CENTS=1

EVPOLY_EVCURVE_CHASE_LADDER_CUTOFF_SEC=60

# submit-time proxy freshness / timing guards (2026-03-07)
EVPOLY_ENDGAME_SUBMIT_PROXY_MAX_AGE_MS=500
EVPOLY_SESSIONBAND_SUBMIT_PROXY_MAX_AGE_MS=500
EVPOLY_SESSIONBAND_MAX_DECISION_TO_SUBMIT_MS=500

