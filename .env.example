# EVPOLY runtime env template
# Copy to .env and fill values.

# Public API endpoints (safe defaults)
POLY_GAMMA_API_URL=https://gamma-api.polymarket.com
POLY_CLOB_API_URL=https://clob.polymarket.com
POLY_POLYGON_RPC_HTTP_URL=https://1rpc.io/matic
POLY_POLYGON_RPC_HTTP_FALLBACK_URL=https://polygon-rpc.com

POLY_PRIVATE_KEY=

# Wallet mode
# 1 = Proxy wallet (email signup): no gas fee paid by user (relayer/gasless)
# 2 = Safe wallet (web3 wallet signup like MetaMask/Rabby): no gas fee paid by user (relayer/gasless)
# 0 = EOA wallet: user pays gas fee directly
POLY_SIGNATURE_TYPE=1
POLY_PROXY_WALLET_ADDRESS=

# Remote builder signer (required on poly-remote)
# Signer defaults can be overridden if needed.
EVPOLY_ORDER_SIGNER_PRIMARY_URL=https://signer.evplus.ai/sign/order
EVPOLY_ORDER_SIGNER_PRIMARY_TOKEN=
EVPOLY_ORDER_SIGNER_FALLBACK_URL=
EVPOLY_SUBMIT_SIGNER_URL=
EVPOLY_BUILDER_REMOTE_SIGNER_TOKEN=
# Relayer API key path for redeem/merge submits (primary path; remote signer is fallback).
# Get these from Polymarket Settings > API Keys:
# https://polymarket.com/settings?tab=api-keys
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=
# Local admin API token (recommended).
# `scripts/remote_onboard.py --write-env-file .env` auto-generates this if missing.
EVPOLY_ADMIN_API_TOKEN=
# Intentionally omitted on poly-remote: POLY_BUILDER_API_KEY / SECRET / PASSPHRASE

# Optional VPS-hosted market discovery (premarket/endgame/shared timeframe paths)
# If host is `alpha.evplus.ai`, runtime auto-retries once on `alpha2.evplus.ai`
# for timeout/429/5xx transport failures.
EVPOLY_REMOTE_MARKET_DISCOVERY_URL=https://alpha.evplus.ai/v1/discovery/timeframe
EVPOLY_REMOTE_MARKET_DISCOVERY_TOKEN=

# VPS-hosted Premarket alpha gate (shared token + proxy wallet)
EVPOLY_REMOTE_PREMARKET_ALPHA_URL=https://alpha.evplus.ai/v1/alpha/premarket/should-trade
EVPOLY_REMOTE_PREMARKET_ALPHA_TOKEN=

# VPS-hosted Endgame alpha policy (shared token + proxy wallet; fail-closed)
EVPOLY_REMOTE_ENDGAME_ALPHA_URL=https://alpha.evplus.ai/v1/alpha/endgame/policy
EVPOLY_REMOTE_ENDGAME_ALPHA_TOKEN=
EVPOLY_ENDGAME_ALPHA_REQUIRED=true

# VPS-hosted MM rewards alpha (selection only; preflight is local in bot runtime)
EVPOLY_REMOTE_MM_REWARDS_SELECTION_ALPHA_URL=https://alpha.evplus.ai/v1/alpha/mm-rewards/selection
EVPOLY_REMOTE_MM_REWARDS_ALPHA_TOKEN=

# Optional VPS-hosted EVSnipe market-spec discovery (remote-first, local fallback on failure)
EVPOLY_REMOTE_EVSNIPE_DISCOVERY_URL=https://alpha.evplus.ai/v1/discovery/evsnipe
EVPOLY_REMOTE_EVSNIPE_DISCOVERY_TOKEN=

# Strategy toggles (default runtime profile)
EVPOLY_STRATEGY_PREMARKET_ENABLE=true
EVPOLY_STRATEGY_ENDGAME_ENABLE=true
EVPOLY_STRATEGY_EVCURVE_ENABLE=false
EVPOLY_STRATEGY_SESSIONBAND_ENABLE=false
EVPOLY_STRATEGY_EVSNIPE_ENABLE=true
EVPOLY_STRATEGY_MM_REWARDS_ENABLE=false
EVPOLY_STRATEGY_MM_SPORT_ENABLE=false

# Optional MM Sport strategy (top-of-book two-outcome BUY quoting on pregame sports reward markets)
EVPOLY_MM_SPORT_EVENT_DRIVEN_ENABLE=true
EVPOLY_MM_SPORT_EVENT_FALLBACK_POLL_MS=200
EVPOLY_MM_SPORT_WS_STALE_MS=600
EVPOLY_MM_SPORT_MIN_REWARD_RATE_PER_DAY=300
EVPOLY_MM_SPORT_QUOTE_SIZE_MULT=1.2
EVPOLY_MM_SPORT_PAIR_BASELINE_QUOTE_SIZE_MULT=1.2
EVPOLY_MM_SPORT_MAX_SHARE_RATIO=0.02
EVPOLY_MM_SPORT_MIN_TOP_DEPTH_USD=100000
EVPOLY_MM_SPORT_PAUSE_AFTER_FILL_SEC=7200
EVPOLY_MM_SPORT_BUST_WINDOW_MS=1000
EVPOLY_MM_SPORT_BUST_SHARES_1S=10000
EVPOLY_MM_SPORT_BUST_PAUSE_MIN_SEC=60
EVPOLY_MM_SPORT_BUST_PAUSE_MAX_SEC=300
EVPOLY_MM_SPORT_RATIO_BREACH_CANCEL_COOLDOWN_MS=200
EVPOLY_MM_SPORT_RATIO_PAUSE_SEC=900
EVPOLY_MM_SPORT_QUOTE_EXPIRY_MIN_SEC=300
EVPOLY_MM_SPORT_QUOTE_EXPIRY_MAX_SEC=600
# Unified strategy base sizing (blank => default 10 USD)
EVPOLY_PREMARKET_BASE_SIZE_USD=
EVPOLY_PREMARKET_FIXED_LADDER_PRICES=0.40,0.30,0.24,0.21,0.15,0.12
EVPOLY_PREMARKET_FIXED_LADDER_WEIGHTS=0.23,0.23,0.17,0.14,0.12,0.11
EVPOLY_PREMARKET_TP_ENABLE=true
EVPOLY_ENDGAME_BASE_SIZE_USD=
EVPOLY_ENDGAME_TICK0_MULTIPLIER=0.20
EVPOLY_ENDGAME_TICK1_MULTIPLIER=0.40
EVPOLY_ENDGAME_TICK2_MULTIPLIER=0.40
EVPOLY_EVCURVE_BASE_SIZE_USD=
EVPOLY_EVCURVE_FILL_FALLBACK_POLL_MS=1500
EVPOLY_SESSIONBAND_BASE_SIZE_USD=
EVPOLY_SESSIONBAND_TAU2_MULTIPLIER=0.30
EVPOLY_SESSIONBAND_TAU1_MULTIPLIER=0.70
EVPOLY_EVSNIPE_SIZE_USD=

# Retention (keeps runtime artifacts bounded; set cron via scripts/install_evpoly_retention_cron.sh)
EVPOLY_EVENTS_ROTATE_KEEP=3
EVPOLY_HISTORY_ROTATE_KEEP=3
EVPOLY_DB_BACKUP_RETENTION_DAYS=3
EVPOLY_HISTORY_DIR_RETENTION_DAYS=3
EVPOLY_RETENTION_CRON_EXPR=17 * * * *

# Startup controls
# Set to false to skip startup pending-order reconcile pass (faster boot).
EVPOLY_STARTUP_PENDING_RECONCILE_ENABLE=true
# Global startup cancel-all (default true). When MM rewards is enabled, keep skip flag true
# to preserve weak-exit SELL continuity across restarts.
EVPOLY_STARTUP_CANCEL_ALL_ORDERS=true
EVPOLY_STARTUP_CANCEL_ALL_SKIP_IF_MM_REWARDS=true

# Optional MM rewards runtime overrides (blank => runtime defaults).
EVPOLY_MM_RUNTIME_MODE=
EVPOLY_MM_HARD_DISABLE=
EVPOLY_MM_POLL_MS=
EVPOLY_MM_REPRICE_MIN_INTERVAL_MS=
EVPOLY_MM_WEAK_EXIT_STALE_FALLBACK_ENABLE=
EVPOLY_MM_COMPETITION_HIGH_FREEZE_ENABLE=
EVPOLY_MM_SCORING_SPREAD_EXTEND_CENTS=
